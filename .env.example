# Public site URL used for canonical links and JSON-LD structured data
VITE_SITE_URL=https://www.brandsamor.com

# Lead form email delivery (required in production)
LEAD_FORM_RECIPIENT=anand@packamor.com
# Sample order notifications to ops (defaults to LEAD_FORM_RECIPIENT)
SAMPLE_ORDER_RECIPIENT=anand@packamor.com
# Comma-separated ISO country codes excluded from GTM/GA4 (default: IN)
ANALYTICS_EXCLUDED_COUNTRIES=IN
# Optional local override to test geo gating (e.g. IN or US)
FORCE_VISITOR_COUNTRY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@brandsamor.com
SMTP_PASS=
# Customer-facing From (display name + address)
SMTP_FROM_NAME=Brandsamor Team
SMTP_FROM_EMAIL=info@brandsamor.com
SMTP_FROM="Brandsamor Team <info@brandsamor.com>"

# MongoDB Atlas
DB_ADDRESS=
DB_USERNAME=
DB_PASSWORD=
DB_QUERY_STRING=
DB_NAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Browser-facing publishable key (same value as STRIPE_PUBLISHABLE_KEY)
VITE_STRIPE_PUBLISHABLE_KEY=
# Stripe Dashboard → Webhooks → endpoint → Signing secret (whsec_...)
# Local: stripe listen --forward-to localhost:5173/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SAMPLE_KIT_AMOUNT_CENTS=10000

# Admin CRM (/login → /admin leads; /admin/orders for paid kits)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Customer account (magic-link login for Create a Scent + Curated Sampling)
# Falls back to ADMIN_SESSION_SECRET / STRIPE_SECRET_KEY when unset
CUSTOMER_SESSION_SECRET=

# AI Scent Studio (/create-a-scent) — OpenAI-compatible provider
# When BASE_URL + CHAT_MODEL are unset, a local consultant fallback is used for UI testing.
SCENT_AI_FEATURE_ENABLED=true
SCENT_AI_BASE_URL=
SCENT_AI_API_KEY=
SCENT_AI_CHAT_MODEL=
SCENT_AI_FORMULA_MODEL=
SCENT_AI_CHAT_TEMPERATURE=0.6
SCENT_AI_FORMULA_TEMPERATURE=0.2
SCENT_AI_MAX_OUTPUT_TOKENS=900
SCENT_AI_MAX_REPAIR_ATTEMPTS=1
SCENT_AI_TIMEOUT_MS=30000
# Sampling brief email recipient (defaults to info@brandsamor.com, then LEAD_FORM_RECIPIENT)
SCENT_STUDIO_BRIEF_RECIPIENT=info@brandsamor.com
