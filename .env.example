# Public site URL used for canonical links and JSON-LD structured data
VITE_SITE_URL=https://www.brandsamor.com

# Lead form email delivery (required in production)
LEAD_FORM_RECIPIENT=anand@packamor.com
# Sample order notifications to ops (defaults to LEAD_FORM_RECIPIENT)
SAMPLE_ORDER_RECIPIENT=anand@packamor.com
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@brandsamor.com
SMTP_PASS=
# Customer-facing From (display name + address)
SMTP_FROM_NAME=Brandsamor Team
SMTP_FROM_EMAIL=info@brandsamor.com
SMTP_FROM="Brandsamor Team <info@brandsamor.com>"

# MongoDB Atlas
DB_ADDRESS=
DB_USERNAME=
DB_PASSWORD=
DB_QUERY_STRING=
DB_NAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Browser-facing publishable key (same value as STRIPE_PUBLISHABLE_KEY)
VITE_STRIPE_PUBLISHABLE_KEY=
# Stripe Dashboard → Webhooks → endpoint → Signing secret (whsec_...)
# Local: stripe listen --forward-to localhost:5173/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SAMPLE_KIT_AMOUNT_CENTS=10000

# Admin orders console (/login → /admin/orders)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
