# Public site URL used for canonical links and JSON-LD structured data
VITE_SITE_URL=https://www.brandsamor.com

# Lead form email delivery (required in production)
LEAD_FORM_RECIPIENT=anand@packamor.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# MongoDB Atlas
DB_ADDRESS=
DB_USERNAME=
DB_PASSWORD=
DB_QUERY_STRING=
DB_NAME=

# Stripe
# Secret key stays server-only. Publishable key is exposed to the browser via GET /api/stripe/config.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Stripe Dashboard → Webhooks → endpoint → Signing secret (whsec_...)
# Local: stripe listen --forward-to localhost:8080/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SAMPLE_KIT_AMOUNT_CENTS=10000
